# Server
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Database (Railway provides this automatically when you add Postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/globalwigs_voip

# Auth
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=30d

# Twilio (get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your-api-key-secret-here
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WEBHOOK_SIGNATURE_VALIDATION=true

# Voicenter (when you get credentials from Voicenter)
VOICENTER_ENABLED=false
VOICENTER_API_KEY=
VOICENTER_SIP_DOMAIN=
VOICENTER_SIP_USERNAME=
VOICENTER_SIP_PASSWORD=

# Firebase Cloud Messaging (for Android push)
# Path to the service-account JSON downloaded from Firebase Console
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=globalwigs-voip

# Number pool policy
NUMBER_QUARANTINE_DAYS=30
DEFAULT_ASSIGNMENT_DAYS=14
